{
  "manifest_version": 2,
  "name": "Morpheus WebHub",
  "version": "1.0.0",
  "description": "Send tabs to your Morpheus WebHub inbox and enable file save/load.",

  "browser_specific_settings": {
    "gecko": {
      "id": "morpheus-webhub@local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "142.0"
    }
  },

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "nativeMessaging"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["file://*/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    },
    "default_title": "Morpheus WebHub"
  },

  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  }
}
